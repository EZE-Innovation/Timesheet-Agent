# ---------------------------------------------------------------------------
# Timesheet Bot - Environment variables (copy to .env and fill in values)
# Never commit .env to source control.
# ---------------------------------------------------------------------------

# Azure Bot / Bot Framework registration (required for Teams and production)
MicrosoftAppId=
MicrosoftAppPassword=

# Optional: App type. Use MultiTenant for production Teams bot.
# MicrosoftAppType=MultiTenant

# Server port (default 3978; Azure App Service sets PORT automatically)
# PORT=3978

# Flowise AI Agent
FLOWISE_URL=https://cloud.flowiseai.com/api/v1/prediction/YOUR_CHATFLOW_ID
FLOWISE_API_KEY=your-flowise-api-key
